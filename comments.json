{"main.py":[{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"8f5c0835_61e38d35","line":319,"updated":"2026-03-06 05:09:23.000000000","message":"this is running in an exception block.  we really want those to be on the \"minimal\" side of things.  i would move all of this to a dedicated function in this class that basically just returns the name of the command to actually run.  if it doesn\u0027t match for whatever reason, return None, and do nothing.\n\n```\nexcept KeyError:\n  corrected_name \u003d self._autocorrect_command_name(...)\n  if corrected_name:\n    name \u003d corrected_name\n    cmd \u003d self.commands[name](\n                repodir\u003dself.repodir,\n                client\u003drepo_client,\n                manifest\u003drepo_client.manifest,\n                outer_client\u003douter_client,\n                outer_manifest\u003douter_client.manifest,\n                git_event_log\u003dgit_trace2_event_log,\n            )\n```\n\ni go this route rather than recurse into _RunLong because of the init at the top of the function.  other option might be to refactor that slightly too.\n\n```\ndef _RunLong(self, name, gopts, argv, git_trace2_event_log):\n  if name not in self.commands:\n    corrected_name \u003d self._autocorrect_command_name(...)\n    if not corrected_name:\n      logger.error(\"repo: \u0027%s\u0027 is not a repo command.  See \u0027repo help\u0027.\", name)\n      return 1\n    name \u003d corrected_name\n\n  ...rest of existing code...\n```","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1023872,"name":"Sam Saccone","email":"samccone@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-3IUGDfdEKnA/AAAAAAAAAAI/AAAAAAAAAAA/D3zas5icmxo/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-3IUGDfdEKnA/AAAAAAAAAAI/AAAAAAAAAAA/D3zas5icmxo/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-3IUGDfdEKnA/AAAAAAAAAAI/AAAAAAAAAAA/D3zas5icmxo/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-3IUGDfdEKnA/AAAAAAAAAAI/AAAAAAAAAAA/D3zas5icmxo/s120-p/photo.jpg","height":120}],"status":"______________________________"},"change_message_id":"c7a8872606ae52532e26c2ce39deaf79c268622a","unresolved":false,"patch_set":1,"id":"424d56d5_2c161c87","line":323,"range":{"start_line":321,"start_character":12,"end_line":323,"end_character":13},"updated":"2026-03-04 19:19:10.000000000","message":"https://github.com/git/git/commit/277cd4c4bd8cca31395846fc80ea28bf2cd4ddf2","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"961775ff_fbbcc049","line":332,"updated":"2026-03-06 05:09:23.000000000","message":"stick to `logger` rather than `print` yourself","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"774750a0_de73b4d6","line":350,"range":{"start_line":347,"start_character":0,"end_line":350,"end_character":35},"updated":"2026-03-06 05:09:23.000000000","message":"this doesn\u0027t correctly handle boolean settings.  autocorrect looks like a non-standard mess, so i think you have to hardcode them.\n\nhttps://git-scm.com/docs/git-config#Documentation/git-config.txt-helpautoCorrect","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"}],"tests/test_main.py":[{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"f3cd7021_8c881c30","updated":"2026-03-06 05:09:23.000000000","message":"this is lacking a proper fileheader (license/copyright) and a module docstring","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"fe22e4a8_7b40193b","line":7,"updated":"2026-03-06 05:09:23.000000000","message":"this feels quite fragile with over use of mocks.  it feels like it\u0027s constructing a house of cards just so it can exercise the specific autocorrect codepath.  this pattern often leads to throw away tests because if we try to update the actual code in ways these mocks don\u0027t expect, we\u0027re left spending more time fighting the mocks.\n\nif that\u0027s your goal, then the function should be refactored in main.py so it can be run more directly without a lot of extra state floating around.","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"2430871c_57a66e2d","line":8,"updated":"2026-03-06 05:09:23.000000000","message":"never mock a stdlib module via its import into another module.  `time.sleep` is the standard point, not `main.time.sleep`.","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2","fix_suggestions":[{"fix_id":"bc9e9b22_33aa58be","description":"prompt_to_edit API","replacements":[{"path":"tests/test_main.py","range":{"start_line":8,"start_character":0,"end_line":9,"end_character":0},"replacement":"    @mock.patch(\"time.sleep\")\n"}]}]},{"author":{"_account_id":1007145,"name":"Mike Frysinger","email":"vapier@google.com","avatars":[{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s32-p/photo.jpg","height":32},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"2bb16096_0486424a","line":9,"updated":"2026-03-06 05:09:23.000000000","message":"there\u0027s no reason to mock this at all in this file","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2","fix_suggestions":[{"fix_id":"114795c4_8cab24a7","description":"prompt_to_edit API","replacements":[{"path":"tests/test_main.py","range":{"start_line":9,"start_character":0,"end_line":11,"end_character":0},"replacement":"    def test_autocorrect_positive(self, mock_sleep):\n"},{"path":"tests/test_main.py","range":{"start_line":35,"start_character":0,"end_line":37,"end_character":0},"replacement":"    def test_autocorrect_negative(self):\n"},{"pa