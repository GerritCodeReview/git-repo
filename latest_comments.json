AAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s56-p/photo.jpg","height":56},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s100-p/photo.jpg","height":100},{"url":"https://lh4.googleusercontent.com/-Y3zUgGhobi0/AAAAAAAAAAI/AAAAAAAAAAA/8cAZ9Dk_cwY/s120-p/photo.jpg","height":120}]},"change_message_id":"c817363e8e1dd79b0081221620e470e2b5d57aab","unresolved":true,"patch_set":1,"id":"8f5c0835_61e38d35","line":319,"updated":"2026-03-06 05:09:23.000000000","message":"this is running in an exception block.  we really want those to be on the \"minimal\" side of things.  i would move all of this to a dedicated function in this class that basically just returns the name of the command to actually run.  if it doesn\u0027t match for whatever reason, return None, and do nothing.\n\n```\nexcept KeyError:\n  corrected_name \u003d self._autocorrect_command_name(...)\n  if corrected_name:\n    name \u003d corrected_name\n    cmd \u003d self.commands[name](\n                repodir\u003dself.repodir,\n                client\u003drepo_client,\n                manifest\u003drepo_client.manifest,\n                outer_client\u003douter_client,\n                outer_manifest\u003douter_client.manifest,\n                git_event_log\u003dgit_trace2_event_log,\n            )\n```\n\ni go this route rather than recurse into _RunLong because of the init at the top of the function.  other option might be to refactor that slightly too.\n\n```\ndef _RunLong(self, name, gopts, argv, git_trace2_event_log):\n  if name not in self.commands:\n    corrected_name \u003d self._autocorrect_command_name(...)\n    if not corrected_name:\n      logger.error(\"repo: \u0027%s\u0027 is not a repo command.  See \u0027repo help\u0027.\", name)\n      return 1\n    name \u003d corrected_name\n\n  ...rest of existing code...\n```","commit_id":"f13d08e6c3fcc53b9f80b705c88f1be0ef5636c2"},{"author":{"_account_id":1023872,"name":"Sam Saccone","email":"samccone@google.com","avatars":[{"url"